# Auto detect text files and normalize to LF
* text=auto eol=lf

# Explicitly set LF for code files
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Ensure package files use LF
package.json text eol=lf
package-lock.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.mp3 binary
